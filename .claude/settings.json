{
  "respectGitignore": true,
  "permissions": {
    "defaultMode": "dontAsk",
    "additionalDirectories": [
      "..",
      "/",
      "~"
    ],
    "allow": [
      "Bash",
      "Read(//**)",
      "Edit(//**)",
      "Write(//**)",
      "WebFetch"
    ],
    "deny": [
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(//**/.env)",
      "Read(//**/.env.*)",
      "Read(**/*secret*)",
      "Read(**/*token*)",
      "Read(**/*api_key*)",
      "Read(**/*apikey*)",
      "Read(~/.ssh/**)",
      "Read(~/.gnupg/**)",
      "Read(//**/.ssh/**)",
      "Read(//**/.gnupg/**)",
      "Read(**/.ssh/**)",
      "Read(**/.gnupg/**)",
      "Read(**/id_rsa*)",
      "Read(**/id_ed25519*)",

      "Edit(**/.env)",
      "Edit(**/.env.*)",
      "Edit(//**/.env)",
      "Edit(//**/.env.*)",
      "Edit(**/*secret*)",
      "Edit(**/*token*)",
      "Edit(**/*api_key*)",
      "Edit(**/*apikey*)",
      "Edit(~/.ssh/**)",
      "Edit(~/.gnupg/**)",
      "Edit(//**/.ssh/**)",
      "Edit(//**/.gnupg/**)",
      "Edit(**/.ssh/**)",
      "Edit(**/.gnupg/**)",
      "Edit(**/id_rsa*)",
      "Edit(**/id_ed25519*)",

      "Write(**/.env)",
      "Write(**/.env.*)",
      "Write(//**/.env)",
      "Write(//**/.env.*)",
      "Write(**/*secret*)",
      "Write(**/*token*)",
      "Write(**/*api_key*)",
      "Write(**/*apikey*)",
      "Write(~/.ssh/**)",
      "Write(~/.gnupg/**)",
      "Write(//**/.ssh/**)",
      "Write(//**/.gnupg/**)",
      "Write(**/.ssh/**)",
      "Write(**/.gnupg/**)",
      "Write(**/id_rsa*)",
      "Write(**/id_ed25519*)",

      "Bash(git push --force:*)",
      "Bash(git push --force-with-lease:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean:*)",
      "Bash(rm -rf:*)",
      "Bash(rm -r -f:*)",
      "Bash(shutdown:*)",
      "Bash(reboot:*)"
    ]
  }
}
