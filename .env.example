# Claude Code Python MVP - Environment Configuration
# 复制此文件为 .env 并填入实际值

# ===== LLM 配置 =====

# DeepSeek API 密钥 (必需)
DEEPSEEK_API_KEY=your_api_key_here

# DeepSeek API 端点 (可选，默认使用官方端点)
# 内网部署示例: DEEPSEEK_BASE_URL=http://internal-api:8080/v1
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# 默认模型 (可选，默认: deepseek-chat)
DEEPSEEK_MODEL=deepseek-chat

# ===== 应用配置 =====

# 日志级别 (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# 最大对话轮数 (可选，默认: 100)
MAX_CONVERSATION_TURNS=100

# 流式输出超时时间 (秒，默认: 120)
STREAM_TIMEOUT=120

# ===== 权限配置 =====

# 默认权限策略 (dontAsk, ask, deny)
# dontAsk: 自动允许所有操作
# ask: 需要确认危险操作
# deny: 拒绝所有文件写入和危险命令
DEFAULT_PERMISSION_MODE=ask

# ===== 路径配置 =====

# 用户配置目录 (可选，默认: ~/.claude)
CLAUDE_USER_DIR=~/.claude

# 项目配置目录 (可选，默认: .claude)
CLAUDE_PROJECT_DIR=.claude

# ===== Windows 7 兼容性 =====

# PowerShell 执行路径 (Windows 7 默认)
# Windows: powershell.exe
# Unix: /bin/bash
SHELL_EXECUTABLE=powershell.exe

# 文件编码 (默认: utf-8)
FILE_ENCODING=utf-8

# ===== 高级配置 =====

# 并行任务最大数 (默认: 4)
MAX_PARALLEL_TASKS=4

# Checkpoint 自动保存间隔 (秒，0=禁用)
CHECKPOINT_AUTO_SAVE_INTERVAL=300

# SSL 证书验证 (内网环境可能需要禁用)
# VERIFY_SSL=false
VERIFY_SSL=true

# CA 证书路径 (可选，用于自签名证书)
# CA_CERT_PATH=/path/to/ca-bundle.crt
